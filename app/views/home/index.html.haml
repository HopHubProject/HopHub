.row.justify-content-center.text-center.py-3
  .col-12.col-lg-6
    =image_tag('hophub.png', alt: 'logo-hophub', width: '260', id: 'logo-hophub', class: 'd-inline-block')
    %div
      =link_to new_event_path, class: "btn btn-primary btn-lg" do
        %i.bi.bi-calendar-plus.me-1
        = t("create_event.title")

.row.justify-content-center.mt-4
  .col-12.col-lg-9
    .card-soft.card-soft--accent.p-4.mb-4
      %h1= t('welcome.title')
      -t('welcome.text').each do |text|
        %p.mb-2= text

.row.justify-content-center
  .col-12.col-lg-9
    .card-soft.p-4.mb-4
      %h1= t('how-it-works.title')

      .how-it-works
        %h2
          %i.bi.bi-calendar-plus
          =t('how-it-works.create-event.title')
        %p=t('how-it-works.create-event.text')

        %h2
          %i.bi.bi-gift
          =t('how-it-works.add-offer.title')
        %p=t('how-it-works.add-offer.text')

        %h2
          %i.bi.bi-hand-thumbs-up
          =t('how-it-works.ride-request.title')
        %p=t('how-it-works.ride-request.text')

        %h2
          %i.bi.bi-chat-dots
          =t('how-it-works.match.title')
        %p=t('how-it-works.match.text')

        %h2
          %i.bi.bi-incognito
          =t('how-it-works.no-indexing.title')
        %p=t('how-it-works.no-indexing.text')

        %h2
          %i.bi.bi-trash
          =t('how-it-works.cleanup.title')
        %p=t('how-it-works.cleanup.text')

  .col-12.col-lg-9
    .card-soft.p-4.mb-4
      %h1= t('about.title')
      -t('about.text',
        tos: link_to(t('tos'), tos_path),
        privacy_policy: link_to(t('privacy_policy'), privacy_path),
        github_project: link_to('GitHub', 'https://github.com/HopHubProject')).each do |text|
        %p= text.html_safe

  -if @instance_info_text.present?
    .col-12.col-lg-9
      .card-soft.p-4.mb-4
        %h1= @instance_info_title
        = @instance_info_text.html_safe
