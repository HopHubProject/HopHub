<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.5;
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background-color: #ffffff;
      }
      h1 {
        color: #ff8a02;
        font-size: 1.3rem;
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #ffe4c4;
      }
      h2 {
        font-size: 1rem;
        margin: 1.5rem 0 0.5rem;
        color: #333;
      }
      p {
        margin: 0 0 1rem;
      }
      a {
        color: #ff8a02;
      }
      .button {
        display: inline-block;
        background-color: #ff8a02;
        color: #ffffff !important;
        padding: 10px 18px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        margin: 4px 0;
      }
      .secret-link {
        background-color: #f6f6f6;
        border-left: 3px solid #ff8a02;
        padding: 10px 14px;
        margin: 0.5rem 0 1rem;
        font-family: monospace;
        font-size: 0.85rem;
        word-break: break-all;
      }
      .quote {
        background-color: #f6f6f6;
        border-left: 3px solid #ccc;
        padding: 12px 16px;
        margin: 1rem 0;
        white-space: pre-wrap;
      }
      .data-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0;
      }
      .data-list li {
        background-color: #f6f6f6;
        padding: 12px 16px;
        margin-bottom: 10px;
        border-radius: 4px;
      }
      .signoff {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #eee;
        color: #666;
        font-size: 0.9rem;
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
