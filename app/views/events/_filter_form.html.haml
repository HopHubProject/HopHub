- filter_active = @filter.active?
.row.justify-content-center.mt-2
  .col-12.col-lg-12
    .accordion#filterAccordion
      .accordion-item
        %h2.accordion-header.pt-0#filterHeading
          %button.accordion-button{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#filterCollapse", "aria-expanded": filter_active, "aria-controls": "filterCollapse", class: ("collapsed" unless filter_active)}
            %h3.pt-2= t('offers.filter.title')
        #filterCollapse.accordion-collapse.collapse{class: ("show" if filter_active), "aria-labelledby": "filterHeading", "data-bs-parent": "#filterAccordion"}
          .accordion-body
            %p
              =t('offers.filter.text')

            =simple_form_for @filter, url: event_path(@event), method: :get,
              html: { class: 'mb-1', data: { controller: "geocoder filter-clear", "geocoder-url-value": postal_code_search_path } } do |f|
              =hidden_field_tag :locale, I18n.locale
              =f.hidden_field :latitude,
                data: { "geocoder-target": "latitude", "filter-clear-target": "field" }
              =f.hidden_field :longitude,
                data: { "geocoder-target": "longitude", "filter-clear-target": "field" }

              .row
                .col-12.col-md-3
                  =f.input :location, class: 'form-control', label: false,
                    wrapper: :horizontal_form_no_validation, required: false, novalidate: true,
                    input_html: { required: false, novalidate: true, data: { "geocoder-target": "location", "filter-clear-target": "field", action: "input->geocoder#resolve" } }

                .col-12.col-md-3
                  =f.input :country, as: :select, class: 'form-control', label: false,
                    collection: @countries, wrapper: :horizontal_form_no_validation, include_blank: false,
                    required: false, novalidate: true,
                    input_html: { required: false, novalidate: true, data: { "geocoder-target": "country", "filter-clear-target": "field", action: "input->geocoder#clear" } }

                .col-12.col-md-3
                  =f.input :radius,
                    as: :select,
                    class: 'form-control',
                    label: false,
                    collection: OffersFilter::RADIUSES,
                    wrapper: :horizontal_form_no_validation,
                    include_blank: false,
                    novalidate: true,
                    input_html: { required: false, novalidate: true },
                    required: false

                .col-12.col-md-3.text-center
                  =f.submit t('offers.filter.apply'), class: 'btn btn-primary mx-2', formnovalidate: true

                  %button.btn.btn-secondary{ type: "button", data: { action: "click->filter-clear#clear" } }
                    =t('offers.filter.clear')

              -if @filter.active?
                .col-12.col-md-12.text-center
                  .row
                    %p.mt-3.mb-0.text-muted
                      =t('offers.filter.active', n: @filtered_offers.count, total: @offers.count)
