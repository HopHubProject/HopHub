- kind = f.object.kind || OfferContact::KINDS.first
- kind_options = OfferContact::KINDS.map { |k| [t("offer_contact.kind.#{k}"), k, { "data-placeholder" => placeholder_for_contact_kind(k) }] }
.row.g-2.mb-2.align-items-center{data: {"offer-contacts-target": "row"}}
  -if f.object.persisted?
    =f.hidden_field :id
    =f.hidden_field :_destroy, value: "0", data: {"offer-contacts-target": "destroyFlag"}
  .col-auto
    %i.fs-5{class: icon_class_for_contact_kind(kind), data: {"offer-contacts-target": "icon"}}
  .col-sm-3
    =f.select :kind,
      options_for_select(kind_options, kind),
      {},
      class: 'form-select form-select-sm',
      data: { action: "change->offer-contacts#kindChanged" }
  .col
    =f.text_field :value,
      class: 'form-control form-control-sm',
      placeholder: placeholder_for_contact_kind(kind),
      data: {"offer-contacts-target": "value"}
  .col-auto
    %button.btn.btn-sm.btn-outline-danger{type: 'button', data: { action: "click->offer-contacts#remove" }, "aria-label": t('offer_delete.title')}
      %i.bi.bi-trash
