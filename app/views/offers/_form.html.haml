=turbo_frame_tag "offer_form" do
  =simple_form_for [@event, @offer],
    html: { data: { controller: "geocoder transport-collapse", "geocoder-url-value": postal_code_search_path } } do |f|
    =f.hidden_field :latitude,  data: { "geocoder-target": "latitude" }
    =f.hidden_field :longitude, data: { "geocoder-target": "longitude" }
    =f.hidden_field :token, value: params[:token]

    =f.input :name
    -if method == :new
      =f.input :email
    =f.input :phone
    =f.input :direction, as: :select,
      collection: Offer::DIRECTIONS.map { |v| [t(v), v] }
    =f.input :location,
      input_html: { data: { "geocoder-target": "location", action: "input->geocoder#resolve" } }
    =f.input :country, as: :select, class: 'form-control', collection: @countries,
      wrapper: :horizontal_form_no_validation, include_blank: false, novalidate: true,
      input_html: { required: false, novalidate: true, data: { "geocoder-target": "country", action: "input->geocoder#clear" } }

    =f.input :transport, as: :select,
      collection: Offer::TRANSPORTS.map { |v| [t("transport.#{v}"), v] },
      include_blank: true,
      blank: t('simple_form.labels.offer.transport'),
      input_html: { data: { "transport-collapse-target": "select", action: "change->transport-collapse#sync" } }
    .collapse#carInputs{ data: { "transport-collapse-target": "panel" } }
      =f.input :driver, as: :boolean,
        label: t('simple_form.labels.offer.driver-needed'),
        hint: t('simple_form.hints.offer.driver-needed')
      =f.input :seats,
        hint: t('simple_form.hints.offer.seats-available')
    =f.input :date, as: :string,
      input_html: { value: @offer.date&.strftime('%d/%m/%Y %H:%M'),
                    data: { controller: "timepicker", "timepicker-locale-value": I18n.locale, "timepicker-max-date-value": @event.end_date } }
    =f.input :notes, input_html: { rows: 5 }

    -if method == :new
      .row.mb-3
        .col-sm-3
        .col-sm-9
          =render 'altcha/widget',
            label: terms_and_conditions_prompt,
            verified: terms_and_conditions_accepted,
            error: @offer.errors[:altcha].any?
          =f.error :altcha, class: 'altcha-error'

    .row.mb-3
      .col-sm-3
      .col-sm-9.col-lg-3
        =f.submit submit_text, class: 'btn btn-primary w-100 mt-1'

      .col-sm-9.col-lg-3
        -if method == :new
          =link_to t('cancel'), event_offers_path(@event, direction: @offer.direction),
            class: 'btn btn-default btn-light w-100 mt-1', role: 'button'
        -else
          =link_to t('offer_delete.title'),
            event_offer_destroy_path(@offer.event, @offer, token: params[:token], method: :delete),
            class: 'btn btn-default btn-danger w-100 mt-1',
            role: 'button',
            data: { turbo_method: :delete, turbo_confirm: t('offer_delete.confirmation') }
